<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Dashboard View using Board -->
    <record id="board_bi_dashboard_form" model="ir.ui.view">
        <field name="name">board.bi.dashboard.form</field>
        <field name="model">board.board</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Enterprise BI Dashboard">
                <board style="1-2">
                    <column>
                        <action name="%(action_bi_sales_analysis)d" string="Sales Trend" />
                        <action name="%(action_bi_account_analysis)d" string="Invoicing Trend" />
                    </column>
                    <column>
                        <action name="%(action_bi_purchase_analysis)d" string="Purchase Trend" />
                        <action name="%(action_bi_crm_analysis)d" string="CRM Opportunities" />
                        <action name="%(action_bi_inventory_analysis)d" string="Inventory Moves" />
                    </column>
                </board>
            </form>
        </field>
    </record>

    <!-- Dashboard Action -->
    <record id="action_bi_dashboard" model="ir.actions.act_window">
        <field name="name">Executive Dashboard</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="usage">menu</field>
        <field name="view_id" ref="board_bi_dashboard_form"/>
    </record>
</odoo>
